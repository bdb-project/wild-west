with
  description "The west bank of the river is not much different to the east bank, except that the river is now to the east. Hoof prints wind their way westward towards the hills.",
  e_to
  [;
    print (string)FERRYMAN_TAKES_YOU_ACROSS;
    return room18;
  ],
  w_to room20,
  before
  [;
    Hint:
      "If you've left anything behind, you can get on the barge and the ferryman will take you back across the river.";
    Listen:
      print_ret (string)HEAR_RUNNING_WATER;
    Swim:
      print_ret (string)NO_NEED_TO_RISK_DROWNING;
  ],
has light;

