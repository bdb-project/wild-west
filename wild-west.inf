Constant Story "Wild West";
Constant Headline "^Kenneth Johnson trilogy #1^Copyright (c) 2025 Gianluca Girelli and Garry Francis^https://bdb-project.itch.io^Type ABOUT for further info and credits.^^";

Array UUID_ARRAY string "UUID://e248bed6-8eaf-43e8-8c30-5e13070c13fc//";
#Ifdef UUID_ARRAY;
#Endif;

Release 2;
Serial "251014";

!Inform 6 constants
Constant DEATH_MENTION_UNDO;
Constant MAX_CARRIED = 10;
Constant NO_SCORE;

!PunyInform constants
Constant CUSTOM_ABBREVIATIONS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_PRINT_SCENERY_CONTENTS;
Constant OPTIONAL_PROVIDE_UNDO;
Constant OPTIONAL_SIMPLE_DOORS;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_DIG_NO_USE "You have better things to do than dig for buried treasure.";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
Constant MSG_PRAY_DEFAULT "You pray that you can find your wife and daughter and they're unharmed.";
Constant MSG_SHOUT_DEFAULT "~Yeehaa!~";
Constant MSG_SING_DEFAULT "~Oh give me a home where the buffalo roam,^Where the deer and the antelope play,^Where seldom is heard a discouraging word,^And the skies are not cloudy all day.~";
Constant MSG_SMELL_DEFAULT "The only thing you can smell is yourself. You haven't had a bath for days.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_SWIM_DEFAULT "Swimming requires water. Take a look around. Do you see any water here?";
Constant MSG_THINK_DEFAULT "Think Kenneth, think. There must be a way to save Sarah and Betty.";
Constant MSG_WAIT_DEFAULT "Time passes...";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

!Game-specific constants
Constant SOME "some";
Constant ALREADY_DEAD " already dead, so don't waste your ammo.";
Constant DENSE_VEGETATION "The air is filled with the rich scent of earth and vegetation.";
Constant DESERT_DESCRIPTION "Wherever you turn your gaze, the immense ocean of fiery sand disappears to the horizon. A mirage causes tremors in the hot air, making it dance in its rhythm of death. From here, you can go in any direction.";
Constant EERILY_QUIET "The desert is eerily quiet.";
Constant FERRYMAN_TAKES_YOU_ACROSS "You get on the barge and the ferryman takes you to the other side of the river.^^";
Constant GO_BACK_TO "You've left something behind. Go back to the ";
Constant HEAR_RUNNING_WATER "You hear the running water of the Kaywannah River.";
Constant LOST_IN_DESERT "The desert holds many secrets. Examine it and follow the tracks.";
Constant NO_NEED_TO_RISK_DROWNING "There's no need to risk drowning in the river, as the ferryman will now take you across the river at any time.";
Constant REVOLVER_IS_EMPTY "The revolver is empty.";
Constant SHOOT_IT "Shoot it!";
Constant TAKE_CARE_OF_BANDITS_FIRST "Take care of the bandits first.";
Constant THAT_WOULD_BE_SUICIDE "That would be suicide. You're unarmed.";
Constant THIS_IS_NOT_TIME_TO "This is not the time to ";
Constant TIME_TO_DEAL_WITH_BANDITS "It's time to deal with those bandits, wild west style!";
Constant YOU_SEE_HOOF_PRINTS "You see a faint trace of hoof prints ";
Constant YOULL_NEED_WEAPON "You'll need a weapon to deal with it.";

!Replaced actions
Replace _UpdateDarkness;
Replace GoSub; !Delete if diagonal directions are used
Replace LockSub;
Replace UnlockSub;

Include "globals.h";

!Game-specific variables

!========================================
! Entry point routines
!========================================
[ DeathMessage;
  if (deadflag == 3)
    print "You have failed";
];

[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  location = room01;
  lookmode = 2;
  move clothes to player;
  no_implicit_actions = true;
  player.description = PlayerDescription;
  "^In the years following the American Civil War, you lead a simple life as a cowboy. Despite the low wage, you scrimp and save and manage to buy a small ranch near Tucson, Arizona, where you live with your wife Sarah and daughter Betty. You dream of a bright future for your daughter and work hard every day to earn the money needed to provide her with a good education.^^Then, one day, your peaceful existence is shattered when Pablo Cortez and his gang raid your ranch on their return to Nogales after a robbery in Tucson. They shoot you in the head and leave you for dead. Luckily for you, the wound is superficial, but, when you come to, you discover that your life savings have been stolen, and Sarah and Betty have been kidnapped. You dress your wound and quickly recover, determined to find Sarah and Betty.^^A few hours later, you're in hot pursuit of Cortez's gang. In retrospect, this was a stupid thing to do on your own. Halfway through the desert, your horse dies from the heat and exertion. You're now by yourself, on foot, and your horse lies dead at your feet.^^This is a life or death situation. Despite the odds, you must press on if you want to see your family alive again, but consider every move carefully, as the Wild West is a deadly and unforgiving place.^";
];

!========================================
! Classes
!========================================
Class OpenableContainer
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
has;

Class Surface
with
  invent
  [;
    if (inventory_stage == 2 && child(self) == 0)
      rtrue;
  ],
has supporter;

!========================================
! Inventory
!========================================
!----------------------------------------
! Clothes
!----------------------------------------
Object clothes "clothes"
with
  article "your",
  name 'clothes' 'clothing',
  description "You're a cowboy and dressed accordingly.",
  before
  [;
    Disrobe:
      "You'd better not. You need your clothes to protect you from the blazing desert sun.";
  ],
has clothing pluralname worn;

!========================================
! Room 1: Desert
!========================================
Object room01 "Desert"
with
  description "You're deep in the desert on the road that brought you from Tucson. The road heads to Nogales, which is somewhere further to the south.",
  n_to "You can go back home by heading north, but you have to rescue your family first.",
  s_to room02,
  before
  [;
    Hint:
      if (revolver notin player)
        "You had a weapon when you started out. Don't head into the desert without it.";
      "You have to rescue your family, so follow the road to Nogales.";
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!----------------------------------------
! Desert (floating object)
!----------------------------------------
Object "desert"
with
  name 'desert' 'sand' 'ocean' 'of' 'fiery' 'sandy' 'landscape',
  description
  [;
    print "The desert is harsh and unforgiving, and hot as Hell itself. ";
    if (location == room01)
      "It's huge, hopeless and deadly. The road peters out to the south.";
    if (hoof_prints in location)
      print_ret (string)YOU_SEE_HOOF_PRINTS, "in the sand.";
    else
      "The sun-baked soil is too hard to detect any hoof prints.";
  ],
  each_turn
  [;
    switch (random(50))
    {
      1: "^A vulture flies high in the sky. It may have spotted your dead horse.";
      2: "^A coyote barks somewhere in the distance.";
      3: "^A cloud of desert insects hovers briefly in the air, then flies off.";
      4: "^The silence of the desert is unnerving.";
      5: "^The heat is stifling.";
      6: "^The sun is relentless.";
      7: "^You wipe the sweat from your brow.";
      8: "^You feel a trickle of perspiration running down your back.";
      9: "^Some sort of bug scitters across the parched desert in front of you, then it's gone.";
      10: "^The hot sun beats down on you.";
    }
  ],
  found_in room01 room02 room03 room04 room05 room06 room07 room08 room09 room11,
has scenery;

!----------------------------------------
! Mirage (floating object)
!----------------------------------------
Object "mirage"
with
  name 'mirage' 'horizon' 'shimmering' 'lake' 'heat' 'haze',
  description "The mirage looks like a shimmering lake on the horizon, but you know it's just a trick that the desert plays with your mind from the heat haze.",
  found_in room01 room02 room03 room04 room05 room06,
has scenery;

!----------------------------------------
! Road
!----------------------------------------
Object "road" room01
with
  name 'road' 'dirt' 'strip' 'sun-hardened' 'terrain',
  description "It's nothing more than a dirt strip of sun-hardened terrain.",
has scenery;

!----------------------------------------
! Dead horse
!----------------------------------------
Object horse "dead horse" room01
with
  name 'dead' 'horse'' faithful',
  description "It's your faithful horse. You asked too much of him and now he lays dead.",
  before
  [;
    Shoot:
      print_ret "He's", (string)ALREADY_DEAD;
    Take:
      "Don't be silly. He's a horse, not a horse shoe.";
  ],
has animate static supporter;

!----------------------------------------
! Saddle
!----------------------------------------
Object saddle "saddle" horse
with
  name 'sturdy' 'leather' 'saddle',
  description "It's a sturdy leather saddle, with a saddle bag attached.",
  before
  [;
    Take:
      "The saddle is of no use to you without a horse to ride.";
  ],
has static supporter;

!----------------------------------------
! Saddle bag
!----------------------------------------
Object saddle_bag "saddle bag" horse
class OpenableContainer
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'saddle' or 'bag')
    {
      i++;
      if (nw == 'saddle')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "It's the saddle bag attached to the saddle. ";
    <<Search self>>;
  ],
  before
  [;
    Take:
      "You can't. It's attached to the saddle.";
  ],
has container openable static;

!----------------------------------------
! Revolver
!----------------------------------------
Object revolver "revolver" saddle_bag
with
  name 'colt' 'revolver' 'handgun' 'pistol' 'gun' 'guns//p' 'weapon' 'weapons//p' 'single-action' 'single' 'action' 'army' 'm1873' 'peacemaker' '45' 'calibre',
  description
  [;
    print "It's a Colt single-action army revolver, also known as the M1873 or 'Peacemaker'. It's a 45 calibre handgun, originally made for the US Army in 1873. It's currently ";
    if (bullets.number == 0)
      "empty.";
    print "loaded with ", bullets.number, " bullet";
    if (bullets.number > 1)
      print "s";
    ".";
  ],
  before
  [;
    Load:
      "It's already loaded with ", bullets.number, " bullets and you don't have any more.";
  ],
  add_to_scope bullets,
has;

!----------------------------------------
! Bullets
!----------------------------------------
Object bullets "bullets"
with
  name 'bullet' 'bullets' 'ammo',
  description
  [;
    if (self.number == 0)
      print_ret (string)REVOLVER_IS_EMPTY;
    print "There are ", self.number, " bullet";
    if (self.number > 1)
      print "s";
    " in the revolver.";
  ],
  before
  [;
    Take:
      if (self.number == 0)
        print_ret (string)REVOLVER_IS_EMPTY;
      print "Leave the bullet";
      if (self.number > 0)
        print "s";
      " in the revolver in case you need them.";
  ],
  number 6,
has pluralname scenery;

!========================================
! Room 2: Desert
!========================================
Object room02 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room01,
  s_to room02,
  e_to room03,
  w_to room04,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!----------------------------------------
! Hoof prints (floating object)
!----------------------------------------
Object hoof_prints "hoof prints"
with
  name 'faint' 'trace' 'of' 'hoof' 'print' 'prints' 'track' 'tracks',
  description
  [;
    print (string)YOU_SEE_HOOF_PRINTS, "heading ";
    switch (location)
    {
      room02: "east and west.";
      room03: "in a U-turn back to the west.";
      room04: "west then south.";
      room05: "east then south.";
      room06: "south.";
      room07: "south. Now that the ground is firmer, you can see that they were left by a group of horses, possibly five. Some of the hoof prints are deeper than the others, suggesting that those horses were carrying a heavier load, possibly your wife and daughter.";
      room09: "west, although there is a confused mass of tracks around the stagecoach before heading off in that direction.";
    }
  ],
  found_in room02 room03 room04 room05 room06 room07 room09,
has pluralname scenery;

!========================================
! Room 3: Desert
!========================================
Object room03 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room03,
  s_to room03,
  e_to room03,
  w_to room02,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!========================================
! Room 4: Desert
!========================================
Object room04 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room04,
  s_to room06,
  e_to room02,
  w_to room05,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!========================================
! Room 5: Desert
!========================================
Object room05 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room04,
  s_to room05,
  e_to room06,
  w_to room05,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!========================================
! Room 6: Desert
!========================================
Object room06 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room05,
  s_to
  [;
    print "You're out of the worst of the desert. The ground is much firmer now.^^";
    return room07;
  ],
  e_to room04,
  w_to room06,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!========================================
! Room 7: Southern Outskirts of Desert
!========================================
Object room07 "Southern Outskirts of Desert"
with
  description "The desert heat is relentless and the landscape never seems to change. On the ground, fresh tracks of a group of horses head towards the south, while to the east there's an unusual circular depression. Towards the north the trail leads back to the desert.",
  n_to
  [;
    print "You're back in the sandy desert. Don't spend too long here, as the heat is relentless^^";
    return room06;
  ],
  s_to room09,
  e_to room08,
  before
  [;
    Hint:
      if (mineral in nothing)
        "If the desert left you depressed, the cure may be found in the depression.";
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!----------------------------------------
! Trail (floating object)
!----------------------------------------
Object "trail"
with
  name 'trail',
  description
  [;
    print "The trail runs ";
    if (self in room07)
      "north and south.";
     if (self in room09)
       "north and west.";
     if (self in room11)
       "east and west, with a faint branch to the north.";
     else
       "north and south, but it's very faint.";
  ],
  found_in room07 room09 room11 room12 room13,
has scenery;

!----------------------------------------
! Depression (floating object)
!----------------------------------------
Object "depression"
with
  name 'circular' 'depression' 'crater',
  description "It's a large circular depression, several dozen yards in diameter. The sand around the edges of the depression has solidified, as though it's been exposed to extreme heat, even hotter than the desert sun. You wonder whether this might be a crater left by an ancient meteorite.",
  before
  [;
    Enter:
      if (self in room07)
        <<Go FAKE_E_OBJ>>;
    Exit:
      if (self in room08)
        <<Go FAKE_W_OBJ>>;
  ],
  found_in room07 room08,
has scenery;

!========================================
! Room 8: Depression
!========================================
Object room08 "Depression"
with
  description "The depression, arid and jagged, seems to have originated from a powerful explosion. You doubt someone ventured out here to fight, so it's likely the product of an ancient meteorite. Going west will take you back to the trail.",
  w_to room07,
  before
  [;
    Hint:
      if (snake in nothing)
      {
        print "Listen. What do you know that rattles and is found in the desert? ";
        if (revolver notin player)
          print_ret (string)YOULL_NEED_WEAPON;
        else
          print_ret (string)SHOOT_IT;
      }
      if (mineral hasnt moved)
        "Don't leave the mineral behind. It may come in handy.";
    Listen:
      if (snake in nothing)
        "There's something rattling inside the skull.";
      else
        print_ret (string)EERILY_QUIET;
  ],
has light;

!----------------------------------------
! Bison skull
!----------------------------------------
Object skull "bison skull" room08
with
  name 'bison' 'skull',
  description "It's the skull of a bison that probably wandered here from the distant prairie. It's such a long journey just to die alone in the desert. Something is glinting inside, but you also hear an ominous rattling noise coming from inside the skull.",
  before
  [;
    Shoot:
      if (CantBeShot())
        rtrue;
      bullets.number--;
      move snake to location;
      move mineral to location;
      move fragments to location;
      move skull to limbo;
      "BANG! You shoot the skull, reducing it to pieces and killing what was inside. Something is now gleaming in the desert sun.";
    Take, Touch:
      deadflag = 1;
      "As you pick up the skull, you realise the rattling sound you heard was from a big rattlesnake, one of the deadliest creatures of the desert. A single bite is all it takes to lead you to death. You'll never see your family again and your bones will soon be shining white in this ancient crater.";
  ],
  add_to_scope glint,
has;

!----------------------------------------
! Glint
!----------------------------------------
Object glint "glint"
with
  name 'glint' 'flash' 'flashes' 'of' 'light',
  description "There's something inside the skull that reflects small flashes of light.",
  before
  [;
    Take, Touch:
      deadflag = 1;
      "When you reach into the bison skull to get whatever's causing the glint, you feel a sudden sharp pain from the bite of a rattlesnake. You regret your stupidity as you die in the desert sun.";
  ],
has scenery;

!----------------------------------------
! Bone fragments
!----------------------------------------
Object fragments "bone fragments"
with
  name 'remaining' 'bone' 'bones' 'broken' 'fragment' 'fragments' 'bison' 'skull',
  description "It's the remaining fragments of the bison skull.",
  before
  [;
    Take:
      "You have no use for broken bones.";
  ],
has pluralname static;

!----------------------------------------
! Mineral
!----------------------------------------
Object mineral "mineral"
with
  name 'odd' 'mineral' 'remains' 'of' 'meteorite',
  description
  [;
    print "It's an odd mineral, possibly the remains of a meteorite that fell to Earth in the dim, distant past. ";
    if (self notin shaman)
      "Someone may find it precious.";
    else
      "The shaman seems to think it's precious.";
  ],
has;

!----------------------------------------
! Dead snake
!----------------------------------------
Object snake "dead snake"
with
  name 'dead' 'snake' 'rattlesnake' 'rattler',
  description "It's a big, dead, rattlesnake, one of the deadliest creatures in the desert. Luckily, you didn't pick up the skull, or you'd be dead.",
  before
  [;
    Shoot:
      print_ret "It's", (string)ALREADY_DEAD;
    Take:
      "It's just a disgusting, and now dead, rattlesnake. Leave it alone.";
  ],
has static;

!========================================
! Room 9: Eastern Trail Out of Desert
!========================================
Object room09 "Eastern Trail Out of Desert"
with
  description "The terrain begins to change and, although the vegetation is still sparse, it feels like you're stepping out of the desert. The trail bends from north to west. The north takes you back to the desert, whereas the west takes you to the mountains. It looks like Cortez wants to hide in the mountains, at least for the moment. Immediately to the south, the remains of a stagecoach remind you how deadly this place is.",
  n_to room07,
  s_to room10,
  w_to room11,
  in_to room10,
  before
  [;
    Hint:
      if (bottle in nothing)
        "There could be something in the stagecoach.";
      print_ret (string)LOST_IN_DESERT;
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has light;

!----------------------------------------
! Thorny vegetation (floating object)
!----------------------------------------
Object "thorny vegetation"
with
  article SOME,
  name 'thorny' 'vegetation' 'bush' 'bushes' 'thorn' 'thorns',
  description "The vegetation consists of low bushes full of thorns, so you'd better not touch them if you know what's good for you.",
  before
  [;
    Take, Touch:
      "Youch!";
  ],
  found_in room09 room11,
has scenery;

!----------------------------------------
! Stagecoach (floating object)
!----------------------------------------
Object "stagecoach"
with
  name 'stagecoach' 'coach' 'red',
  description
  [;
    print "The coach, or what remains of it, is riddled with bullet holes. ";
    if (self in room09)
      "It's painted in red with yellow writing on the side.";
    else
      "It used to be a nice coach. Now it's only a shadow of its former self.";
  ],
  before
  [;
    Enter:
      if (self in room09)
        <<Go FAKE_S_OBJ>>;
    Exit:
      if (self in room10)
        <<Go FAKE_N_OBJ>>;
  ],
  found_in room09 room10,
has scenery;

!----------------------------------------
! Bullet holes (floating object)
!----------------------------------------
Object "bullet holes"
with
  name 'bullet' 'holes',
  description "They're the result of heavy gunfire, perhaps from a robbery.",
  found_in room09 room10,
has pluralname scenery;

!----------------------------------------
! Writing
!----------------------------------------
Object "writing" room09
with
  article SOME,
  name 'yellow' 'writing' 'paint',
  description "The paint is somewhat faded by the sun, but the writing clearly reads, 'Wells Fargo & Co.' and 'U.S. Mail'.",
has scenery;

!========================================
! Room 10: Inside Stagecoach
!========================================
Object room10 "Inside Stagecoach"
with
  description "The interior of the stagecoach has been partially destroyed by gunfire, with the result that the two large leather seats are punctured and stained, probably by human blood. You can leave the stagecoach to the north.",
  n_to room09,
  out_to room09,
  before
  [;
    Hint:
      if (bottle in nothing)
        "Try looking under the seats.";
  ],
has light;

!----------------------------------------
! Seats
!----------------------------------------
Object seats "leather seats" room10
class Surface
with
  name 'leather' 'seat' 'seats',
  description
  [;
    print "They're finely-crafted and look very comfy, if you overlook the holes and the stains. ";
    <<Search self>>;
  ],
  before
  [;
    Enter:
      if (verb_word == 'lie')
        "The seats aren't long enough to lie on.";
      if (verb_word == 'stand')
        "The seats are for sitting on, not standing on.";
      "You don't have time to sit around.";
    LookUnder:
      print "You look under the seats";
      if (bottle notin nothing)
        ", but don't find anything else.";
      move bottle to room10;
      " and find a bottle.";
    Take:
      "The seats are firmly attached to the walls of the stagecoach.";
  ],
has pluralname scenery supporter;

!----------------------------------------
! Blood stains
!----------------------------------------
Object "blood stains" room10
with
  name 'blood' 'stain' 'stains',
  description "The blood stains are now dry and dark, but it's everywhere. Whoever was inside the coach must have suffered deadly wounds.",
has pluralname scenery;

!----------------------------------------
! Bottle of whiskey
!----------------------------------------
Object bottle "bottle"
with
  name 'whiskey' 'half-full' 'bottle' 'of' 'whiskey' 'alcohol',
  description
  [;
    print "It's a half-full bottle of whiskey. It's not one of the best brands available, but that doesn't matter, since ";
    if (self notin miner)
      "you definitely won't be drinking alcohol in this heat. It may come in handy, though.";
    else
      "it now belongs to the miner.";
  ],
  before
  [;
    Drink:
      "Not in this extreme heat or while you're on this quest. Besides, it may come in handy later on.";
  ],
has;

!========================================
! Room 11: Western Trail Out of Desert
!========================================
Object room11 "Western Trail Out of Desert"
with
  description "The long trail from the east continues to the west, where you hear the sound of water. A branch of the trail winds north into a canyon. The canyon is lined with tall boulders, around which vegetation grows, mostly thorny bushes and Saguaro cacti.",
  n_to room12,
  e_to room09,
  w_to room18,
  before
  [;
    Listen:
      print_ret (string)HEAR_RUNNING_WATER;
  ],
has light;

!----------------------------------------
! Canyon (floating object)
!----------------------------------------
Object "canyon"
with
  name 'canyon' 'fallen' 'boulder' 'boulders' 'rock' 'rocks' 'steep' 'side' 'sides' 'wall' 'walls' 'base',
  description "The canyon has steep sides with fallen boulders at its base.",
  before
  [;
    Climb:
      "Stick to the paths and trails.";
  ],
  found_in room11 room12 room13 room14,
has scenery;

!----------------------------------------
! Cacti
!----------------------------------------
Object "cacti" room11
with
  name 'saguaro' 'cactus' 'cacti',
  description "They're Saguaro cacti. Oddly, they only grow here in Arizona and a few surrounding areas.",
  before
  [;
    Take, Touch:
      "Youch!";
  ],
has pluralname scenery;

!========================================
! Room 12: South End of Canyon
!========================================
Object room12 "South End of Canyon"
with
  description "The canyon runs roughly north to south with high walls surrounding you to the east and west. The trail through the canyon is barely visible. On the western wall, a narrow path leads up to the top, but it's very steep.",
  n_to
  [;
    if (cougar hasnt general)
    {
      cougar.time_left = 0;
      StartDaemon(cougar);
    }
    return room13;
  ],
  s_to room11,
  w_to room17,!Conditional, see below
  u_to room17,!Conditional, see below
  before
  [;
    Go:
      if (selected_direction == w_to or u_to)
      {
        if (mineral notin shaman)
          "The path is steep. You don't have enough energy to climb to the top.";
        if (room17 hasnt visited)
          print "Thanks to the food the Indians gave you before leaving the village, you now have the strength to climb the path to the top.^^";
        if (bottle notin miner)
        {
          miner.time_left = 0;
          StartDaemon(miner);
        }
      }
  ],
has light;

!----------------------------------------
! Path (floating object)
!----------------------------------------
Object "path"
with
  name 'path' 'track',
  description
  [;
    print "It's a steep path that climbs the western wall of the canyon.";
    if (mineral notin shaman)
      print " After your travels through the desert, you don't think you'll have enough energy to climb it.";
    "";
  ],
  before
  [;
    Climb:
      if (self in room12)
        <<Go FAKE_W_OBJ>>;
      else
        <<Go FAKE_E_OBJ>>;
  ],
  found_in room12 room17,
has scenery;

!========================================
! Room 13: Middle of Canyon
!========================================
Object room13 "Middle of Canyon"
with
  description "The trail continues through the canyon to the north and south.",
  n_to
  [;
    if (cougar hasnt general)
      "The cougar is blocking your way.";
    else
      return room14;
  ],
  s_to
  [;
    if (cougar hasnt general)
      StopDaemon(cougar);
    return room12;
  ],
  before
  [;
    Hint:
      if (cougar hasnt general)
      {
        print "That cougar looks pretty mean. ";
        if (revolver notin player)
          print_ret (string)YOULL_NEED_WEAPON;
        else
          print_ret (string)SHOOT_IT;
      }
    Listen:
      "A high-pitch wind blows from the north. The exit from the canyon must be near.";
  ],
has light;

!----------------------------------------
! Cougar
!----------------------------------------
Object cougar "cougar" room13
with
  name 'cougar' 'mountain' 'lion',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "It's a cougar, also called a mountain lion. It's one of North America's most widespread predators. ";
    if (self hasnt general)
      "Like other cats, it hunts stealthily, stalking its prey and then bringing it down with a furious leap. You'd better keep your distance or dispose of it pronto.";
    else
      "However, this one won't be doing any more hunting, as it's dead. You don't need to waste any more time with it.";
  ],
  life
  [;
    Attack:
      if (self hasnt general)
        "You can't attack it up close or it will tear you to pieces. Try shooting it.";
      else
        "Don't waste your time. It's already dead.";
  ],
  before
  [;
    Eat:
      if (self hasnt general)
        "It's more likely that the cougar will eat you.";
      if (mineral in shaman)
        "You had a good feed at the Indian village.";
      "I know you're hungry, but you'd need a knife and a fire to cut up the cougar and cook it. Unfortunately, you don't have either.";
    Shoot:
      if (CantBeShot())
        rtrue;
      if (self has general)
        print_ret "It's", (string)ALREADY_DEAD;
      bullets.number--;
      give self general;
      StopDaemon(self);
      "BANG! You shoot the cougar just as it's about to pounce and it falls to the ground, dead.";
    Take:
      print "Seriously? ";
      if (self hasnt general)
        "That cougar would tear you to pieces before you have a chance to take it.";
      else
        "What are you going to do with a dead cougar? If you were back home, you could have barbecue cougar, but out here in the desert, you don't even have a fire.";
  ],
  daemon
  [;
    self.time_left++;
    print "^The cougar";
    switch (self.time_left)
    {
      1: " looks at you with a hungry grin on its face.";
      2: "'s posture is changing and getting more aggressive.";
      3: " is creeping towards you. It's now very close. It looks like you're about to reach the end of your days.";
      4: StopDaemon(self);
        deadflag = 1;
        " attacks you with a leap and bites your neck, causing a fatal wound. Yet, you're still alive when it starts eating your fleshier parts.";
    }
  ],
  time_left 0,
has animate neuter;

!========================================
! Room 14: North End of Canyon
!========================================
Object room14 "North End of Canyon"
with
  description "Now that you're at the north end of canyon, the landscape becomes gentler. A prairie extends to the west and, due to the rains of the monsoon season, it's covered in flowers. The canyon extends to the south.",
  s_to room13,
  w_to room15,
  before
  [;
    Smell:
      if (noun == nothing)
        print_ret (string)DENSE_VEGETATION;
  ],
has light;

!----------------------------------------
! Prairie (floating object)
!----------------------------------------
Object "prairie"
with
  name 'prairie' 'landscape',
  description "The landscape here reveals a prairie in bloom. The rains of the monsoon season have left it carpeted with flowers.",
  found_in room14 room15,
has scenery;

!----------------------------------------
! Flowers (floating object)
!----------------------------------------
Object "flowers"
with
  name 'flowers',
  description "Your wife and daughter would love them. You'd better hurry and rescue them.",
  before
  [;
    Take:
      "You can pick flowers after you've rescued Sarah and Betty.";
  ],
  found_in room14 room15,
has pluralname scenery;

!========================================
! Room 15: Prairie
!========================================
Object room15 "Prairie"
with
  description "You're at the western edge of the prairie, where a long trail winds up the side of a low hill. To the east, you can see the start of the canyon.",
  e_to room14,
  w_to room16,!Conditionally start daemon, see below
  u_to room16,!Conditionally start daemon, see below
  before
  [;
    Go:
      if (selected_direction == w_to or u_to && mineral notin shaman)
      {
        indians.time_left = 0;
        StartDaemon(indians);
      }
    Smell:
      if (noun == nothing)
        print_ret (string)DENSE_VEGETATION;
  ],
has light;

!----------------------------------------
! Hill (floating object)
!----------------------------------------
Object "hill"
with
  name 'hill',
  description
  [;
    print "The hill ";
    if (self in room15)
      "rises to the west.";
    else
      "descends to the east.";
  ],
  before
  [;
    Climb:
      if (self in room15)
        <<Go FAKE_U_OBJ>>;
      else
        <<Go FAKE_D_OBJ>>;
  ],
  found_in room15 room16,
has scenery;

!========================================
! Room 16: Indian Village
!========================================
Object room16 "Indian Village"
with
  description "This is a small Indian village inhabited by a group of Navajo, who have gradually migrated south from northern Arizona as their lands have been progressively occupied. All around you stand their dwellings, called hogans, but you're forbidden to enter them. You can leave the village by going back down the hill to the east.",
  e_to room15,!Stop daemon, see below
  d_to room15,!Stop daemon, see below
  before
  [;
    Go:
      if (selected_direction == e_to or d_to)
        StopDaemon(indians);
    Hint:
      if (mineral notin shaman)
      {
        if (mineral hasnt moved)
          print_ret (string)GO_BACK_TO, "depression.";
        else
          "The Indians value rare trinkets, especially those that have fallen from the sky.";
      }
      if (pouch in nothing)
        "Ask the shaman about the bandits.";
    Listen:
      "The village is filled with the sounds of animals and busy people.";
  ],
has light;

!----------------------------------------
! Indian village
!----------------------------------------
Object "village" room16
with
  article "an",
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'indian' or 'village')
    {
      i++;
      if (nw == 'indian')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "The village is spread out over a large area, but the Indians don't allow you to go wandering around.",
has scenery;

!----------------------------------------
! Hogans
!----------------------------------------
Object "hogans" room16
with
  name 'hogan' 'hogans' 'dwelling' 'dwellings' 'wooden' 'poles' 'tree' 'bark' 'mud',
  description "The hogans are made of wooden poles covered in tree bark and mud. The mud provides insulation, protecting them from the cold at night and the heat during the day. The doorway of each hogan opens to the east so they can get the morning sun as a good blessing.",
  before
  [;
    Enter:
      deadflag = 1;
      "It's forbidden to step into a hogan uninvited and Navajos don't like people with no manner. You have unleashed their wrath. With savage howls, they shoot their arrows at you, killing you on the spot, and then start fighting over your scalp.";
  ],
has pluralname scenery;

!----------------------------------------
! Indians
!----------------------------------------
Object indians "Indians" room16
with
  name 'indian' 'indians' 'warrior' 'warriors' 'navajo',
  description "There's a group of Indian warriors standing before you with menacing grins on their faces. Be careful, it seems that the Indians do not like your presence very much.",
  life
  [;
    Ask, Tell:
      "The Indians just give you a strange look. Maybe they don't understand English.";
    Give, Show:
      if (noun == bottle)
        "Your offer of whiskey becomes a topic of heated debate among the Indians. In the end, they refuse your offer. It seems that white man's firewater is no longer tolerated in this tribe.";
      if (noun ~= mineral)
        "The Indians don't seem interested in ", (the)noun, ". They might be interested in something else, though.";
      move shaman to room16;
      move mineral to shaman;
      StopDaemon(self);
      "The Indians look at the mineral in awe for a few seconds. Then one of them snatches it from you and shouts something towards one of the hogans. After a few moments, an old shaman comes out of the hogan and approaches you.^^The shaman stares at you for a moment then says, ~What you have brought to our people is a sign of great magic and great power. I see that you seek someone and there is hatred in your eyes. So, tell me who it is that you seek and I will help you find and defeat him.~";
    Talk:
      "The warriors are not very talkative. Maybe they don't understand English.";
  ],
  before
  [;
    Attack, Shoot:
      "You're outnumbered, so don't even think about it.";
  ],
  daemon
  [;
    self.time_left++;
    print "^The Indians ";
    switch (self.time_left)
    {
      1: "stare at you with an inquisitive look.";
      2: "look at one another, as if to say, ~What should we do with this intruder?~";
      3: "point to you, then point to the east. They seem to be ushering you away from their village.";
      4: "are losing their patience. You'd better go unless you have something to placate them.";
      5: StopDaemon(self);
         deadflag = 1;
         "You have abused the patience of these people for too long. An arrow pierces your throat. As you fall to your knees, more arrows pierce your body. Later, your scalp will be disputed by the warriors as a symbol of the stupidity of the paleface.";
    }
  ],
  time_left 0,
has animate pluralname;

!----------------------------------------
! Shaman
!----------------------------------------
Object shaman "shaman"
with
  name 'shaman' 'man' 'witch' 'doctor',
  description "The shaman looks like someone who has stood beside his warriors in countless battles. You notice that he's clutching the mineral that you gave the Indians.",
  life
  [;
    Ask, Tell:
      wn = consult_from;
      switch (NextWord())
      {
        'band', 'bandit', 'bandits', 'cortez', 'pablo':
          move pouch to player;
          move shaman to limbo;
          "The shaman says, ~The ones you seek are camped on the other side of the Kaywannah River. You can only defeat them with this powder of death.~ He hands you a leather pouch. You take it and bow in thanks. The shaman then raises his bony hand in farewell and retreats to his hogan.^^Before you leave, the Indians offer you some food, which you gladly accept. After eating, you quickly regain your strength.";
        default:
          "~I'm sorry, but I don't know anything about that.~";
      }
    Give, Show:
      if (noun == bottle)
        "The old shaman shakes his head, muttering something about the madness of palefaces and their liking for firewater.";
    Talk:
      "~Good afternoon, stranger. What do you want to ask me about?~";
  ],
  before
  [;
    Attack, Shoot:
      "Are you crazy? He's a holy man. If you were to hurt the shaman, the Indians would skin you alive and stake you out to be eaten alive by ants while you bake in the desert sun.";
  ],
has animate transparent;

!----------------------------------------
! Leather pouch
!----------------------------------------
Object pouch "leather pouch"
class OpenableContainer
with
  name 'small' 'leather' 'pouch',
  description
  [;
    print "It's the small pouch that the Indian shaman gave you. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun ~= poison)
        "The pouch is only small, so you can't put anything in there apart from the poison powder.";
  ],
has container openable;

!----------------------------------------
! Poison powder
!----------------------------------------
Object poison "poison powder" pouch
with
  article SOME,
  name 'poison' 'powder',
  description "It looks like a mix of different herbs, but it sure is a powerful poison.",
  before
  [;
    Take:
      if (location ~= room21)
        "You'd better leave it in the pouch until it's time to use it or it might blow away.";
  ],
has;

!========================================
! Room 17: Old Mine Entrance
!========================================
Object room17 "Old Mine Entrance"
with
  description "After the tiring climb up the canyon wall, you find yourself in front of the dark mouth of an old mine, the entrance of which is mostly blocked by massive wooden boards. Apart from the entrance to the mine, the only exit from here is east back down to the bottom of the canyon.",
  e_to room12,!Stop daemon, see below
  d_to room12,!Stop daemon, see below
  before
  [;
    Go:
      if (selected_direction == e_to or d_to)
        StopDaemon(miner);
    Hint:
      if (bottle notin miner)
      {
        if (bottle hasnt moved)
          print_ret (string)GO_BACK_TO, "stagecoach.";
        else
          "That miner looks grumpy. Perhaps he's thirsty.";
      }
    Smell:
      "You thought you smelt bad. The reeking scent of the grumpy old miner is even worse.";
  ],
has light;

!----------------------------------------
! Mine entrance
!----------------------------------------
Object "mine entrance" room17
with
  name 'old' 'mine' 'entrance' 'dark' 'mouth',
  description "The mine is no longer in use, so it's likely the miner's home. Who would want to live in such a place?",
  before
  [;
    Enter:
      "It's all boarded up.";
  ],
has scenery;

!----------------------------------------
! Boards
!----------------------------------------
Object "boards" room17
with
  name 'wooden' 'board' 'boards',
  description "For the most part, they block the entrance to the mine.",
  before
  [;
    Take:
      "~Leave them boards alone!~ says the angry miner.";
  ],
has pluralname scenery;

!----------------------------------------
! Old miner
!----------------------------------------
Object miner "old miner" room17
with
  name 'old' 'miner' 'man',
  initial "An old miner stands at the entrance to the mine.",
  description
  [;
    print "The old miner looks like he's got no time to waste with strangers. Maybe he's spent too much time in this lonely place to enjoy the company of others. You notice that he's cradling a rifle in his arms";
    if (bottle notin self)
      ". He may be willing to help you if properly rewarded, but he could also shoot you with that rifle if you bother him too much.";
    else
      " and clutching the bottle of whiskey you gave him. You'd better leave before he loses his patience.";
  ],
  life
  [;
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'band', 'bandits':
          "~They're usually dangerous and so am I. Get lost or I'll shoot you!~";
        'cortez':
          "~I don't know no Cortez. I don't go around asking names.~";
        default:
          "~I don't know anything about that.~";
      }
    Give:
      if (noun == bottle)
      {
        move bottle to miner;
        move nugget to player;
        StopDaemon(self);
        "~Thanks, buddy. That will soothe a parched throat. In exchange for the whiskey, you can have this gold nugget, but don't tell anyone where you got it. Now get out of here.~ You take the nugget and thank the miner.";
      }
    Show:
      if (noun == bottle)
        "You've never met a miner who didn't like a drop of whiskey and this miner looks interested. Maybe you should give it to him.";
    Talk:
      if (bottle notin self)
        "~What do you want?~";
      else
        "~I've paid you for the whiskey, now go away.~";
  ],
  before
  [;
    Shoot:
      if (CantBeShot())
        rtrue;
      bullets.number--;
      deadflag = 1;
      "BANG! The old man is faster than you. Before you can pull the trigger he hits you in the middle of the forehead with a precise rifle shot and you fall into the canyon, your body smashing on the rocks.";
  ],
  daemon
  [;
    self.time_left++;
    print "^The old miner ";
    switch (self.time_left)
    {
      1: "is tapping his foot. ~Strangers aren't welcome here.~";
      2: "is looking impatient. ~Go. Now. Or I'll blow your head off.~ You notice that he's cradling a rifle.";
      3: "is about to lose his patience. You'd better get out of here.";
      4: StopDaemon(self);
        deadflag = 1;
        "has had enough. Suddenly, you see a flash of hatred in the old miner's eyes as he raises his rifle and fires at you! Your lifeless body plummets to the bottom of the canyon, smashing onto the rocks.";
    }
  ],
  time_left 0,
has animate transparent;

!----------------------------------------
! Rifle
!----------------------------------------
Object "rifle" miner
with
  name 'rifle',
  description "It looks like a remnant from the Civil War.",
has scenery;

!----------------------------------------
! Gold nugget
!----------------------------------------
Object nugget "gold nugget"
with
  name 'gold' 'nugget',
  description
  [;
    print "It's a small chunk of gold. It's not enough to get rich, but ";
    if (self notin ferryman)
      "it may be useful in exchange for something else.";
    else
      "it was enough to pay your way across the river.";
  ],
has;

!========================================
! Room 18: East Bank of Kaywannah River
!========================================
Object room18 "East Bank of Kaywannah River"
with
  description "The clear waters of the Kaywannah River rush past here. The river is too wide and deep to wade across on foot. It must be crossed by a barge attached to strong ropes. Some hills can be seen in the distance, towards the west and the trail leads back to the east.",
  e_to room11,
  w_to
  [;
    if (nugget notin ferryman)
      "The ferryman says, ~Not without paying first, stranger.~";
    print (string)FERRYMAN_TAKES_YOU_ACROSS;
    return room19;
  ],
  before
  [;
    Hint:
      if (nugget notin ferryman)
      {
        print "Examine the ferryman and ask him about the river. ";
        if (room17 hasnt visited)
          "Come back when you've got something to pay him.";
        if (bottle notin miner)
          "Perhaps the miner can help.";
        else
          "Pay him!";
      }
      if (room19 hasnt visited)
        "What are you waiting for? Get on the barge!";
    Listen:
      print_ret (string)HEAR_RUNNING_WATER;
    Swim:
      if (nugget in ferryman)
        print_ret (string)NO_NEED_TO_RISK_DROWNING;
      deadflag = 1;
      "You enter the river and try to swim to the opposite bank, but the strong current quickly overwhelms you. The cold water makes you numb and, now breathless, you quickly lose consciousness and drown.";
  ],
has light;

!----------------------------------------
! Hills (floating object)
!----------------------------------------
Object "hills"
with
  name 'hill' 'hills',
  description "Maybe Cortez is hiding there.",
  found_in room18 room19,
has pluralname scenery;

!----------------------------------------
! Kaywannah River (floating object)
!----------------------------------------
Object "river"
with
  name 'kaywannah' 'river' 'clear' 'water' 'waters' 'bank' 'strong' 'current',
  description "The river is wide and deep and rushes by in a strong current, so it can't be crossed on foot. The water in the river is freezing cold, but looks very refreshing.",
  before
  [;
    Drink:
      "You kneel on the ground and take a drink of water from the river. After what you've been through in the desert, you feel so refreshed.";
    Enter:
      <<Swim>>;
  ],
  found_in room18 room19,
has scenery;

!----------------------------------------
! Barge (floating object)
!----------------------------------------
Object "barge"
with
  name 'barge' 'ferry' 'small' 'marine' 'vessel' 'rope' 'ropes',
  description "The barge is a small marine vessel used to carry passengers and cargo across the river. It's securely tied to heavy ropes that cross the river from east to west.",
  before
  [;
    Enter:
      if (self in room18)
        <<Go FAKE_W_OBJ>>;
      else
        <<Go FAKE_E_OBJ>>;
  ],
  found_in room18 room19,
has scenery;

!----------------------------------------
! Ferryman (floating object)
!----------------------------------------
Object ferryman "ferryman"
with
  name 'ferryman' 'man',
  initial "A ferryman is patiently waiting next to his barge.",
  description
  [;
    print "The ferryman looks middle-aged, yet fit. You're guessing that he's younger than he looks and his apparent age is due to his continued exposure to this harsh environment. ";
    if (nugget notin self)
      "He may be willing to help you across the river if properly rewarded.";
    else
      "He clutches the gold nugget. Now that you've paid him, he will ferry you across the river.";
  ],
  life
  [;
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'band', 'bandit', 'bandits', 'gang':
          "~A few people crossed the river yesterday. As I recall, there were five men, a woman, a girl and their horses. I had to make two trips to get them all across.~";
        'barge':
          "~It's my livelihood. If someone wants to cross the river, then I'll take them across...for a fee, of course.~";
        'betty', 'cortez', 'pablo', 'sarah':
          "~I don't go around asking names.~";
        'daughter':
          "~I don't know if it was your daughter, but a young girl crossed the river yesterday.~";
        'girl':
          "~A girl crossed the river yesterday. She was with five men and an older woman. The women looked tired, but unharmed.~";
        'kaywannah', 'river':
          print "~This is the Kaywannah River. Isn't she a beauty? I can take you across ";
          if (nugget notin self)
            "for a fee.~";
          else
            "now that you've paid.~";
        'men':
          "~They sure didn't look like gentlemen, but I mind my own business. You know this is a deadly place.~";
        'wife':
          "~I don't know if it was your wife, but a woman crossed the river yesterday with five men and a younger girl.~";
        'woman':
          "~A woman crossed the river yesterday. She was with five men and a girl.~";
        'women':
          "~They looked tired, but unharmed.~";
        default:
          "~I apologise, but I don't know anything about that.~";
      }
    Give:
      if (noun == bottle)
        "The ferryman takes one look at the bottle and says, ~It's half empty! A half-empty bottle of whiskey won't buy me food to feed the kids and missus. Have you got anything else of value?~";
      if (noun == nugget)
      {
        move nugget to self;
        "~Thank you, sir. That's very generous. You can now cross the river back and forth any time you like.~";
      }
    Show:
      if (noun == nugget)
        "~A gold nugget, eh? That would pay your way across.~";
    Talk:
      "~Good afternoon, stranger. What brings you here?~";
  ],
  before
  [;
    Shoot:
      if (CantBeShot())
        rtrue;
      bullets.number--;
      deadflag = 3;
      "BANG! The poor man stares at you with a look of dismay. then bends over and falls to the ground with a final groan of pain. You've killed him! You can't pull the ferry cable alone, so your family is now condemned.";
  ],
  found_in room18 room19,
has animate transparent;

