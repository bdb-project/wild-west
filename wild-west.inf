!----------------------------------------
! Saddle bags
!----------------------------------------
Object saddle_bags "saddle bags" room21
class OpenableContainer
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'saddle' or 'bag' or 'bags')
    {
      i++;
      if (nw == 'saddle')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "They're leather saddle bags, just like the saddles. ";
    <<Search self>>;
  ],
  before
  [;
    Take:
      "They're attached to the saddles.";
  ],
has container openable pluralname static;

!----------------------------------------
! Canteen
!----------------------------------------
Object canteen "canteen" saddle_bags
class OpenableContainer
with
  name 'tin' 'canteen',
  description
  [;
    print "It's a tin canteen. ";
    <<Search self>>;
  ],
  before
  [;
    Drink:
      if (self hasnt open)
        "You can't, since the canteen is closed.";
      <<Drink water>>;
    Empty:
      if (dead_outlaw in room21)
        "You don't need to bother about that any more.";
      else
        "Don't pour the water out or the bandits will know that someone has been here.";
    Receive:
      if (noun ~= poison)
        "You can only put water in the canteen.";
      move poison to limbo;
      give water general;
      give self ~open;
      StartDaemon(room21);
      "You put the poison powder in the canteen, then close it and give it a shake, hoping that no one will notice the difference. You just hope those bandits don't offer any water to Sarah or Betty.";
    Take:
      if (dead_outlaw in room21)
        "You don't need the canteen any more.";
      else
        "Leave it where it is, or the bandits will notice that it's gone.";
  ],
has container openable static;

!----------------------------------------
! Water
!----------------------------------------
Object water "water" canteen
with
  article SOME,
  name 'water',
  short_name
  [;
    if (self has general)
      print "poisoned ";
    rfalse;
  ],
  description
  [;
    print "It's just water. Those bandits will need to drink it sooner or later.";
    if (self has general)
      print " And when they do, they'll get a nasty surprise.";
    "";
  ],
  before
  [;
    Drink:
      print "As thirsty as you may be, it's better to leave the water for the bandits";
      if (self has general)
        print ", especially now that it's poisoned";
      ".";
    Empty:
      <<Empty canteen>>;
    Receive:
      if (noun == poison)
        <<Insert poison canteen>>;
    Take:
      "You can't take the water out of the canteen, nor do you need to.";
  ],
has;

