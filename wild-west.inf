!========================================
! Room 22: Cortez's Hideout
!========================================
Object room22 "Cortez's Hideout"
with
  description "In front of you, in an unprotected open space, lies Cortez's hideout. From your position, you can't see your family, but it seems that they're held captive in a tent located behind a cluster of trees.",
  w_to
  [;
    if (self.time_left > 2)
      "It's too late. The bandits have seen you, so you'd better act quick.";
    StopDaemon(self);
    return room21;
  ],
  before
  [;
    Hint:
      print_ret (string)TIME_TO_DEAL_WITH_BANDITS;
