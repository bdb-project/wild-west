Object dead_outlaw "dead outlaw"
with
  name 'dead' 'bandit' 'outlaw' 'body' 'corpse' 'man',
  description "It's the body of the outlaw you poisoned with the poison powder. He's now paid for his sins.",
  life
  [;
    Answer, Ask, Talk, Tell:
      "Dead men tell no tales.";
    Attack, Kiss, WakeOther:
      "It's a bit late for that. He's dead.";
    Give, Show:
      "The dead outlaw doesn't seem interested in ", (the)noun, ". I wonder why.";
  ],
  before
  [;
    Hide, Pull, Push, Take:
      "You have no time to waste. Besides, he's too fat and heavy to move. Leave him where he is.";
    Search:
      "You search the body, but don't find anything noteworthy.";
    Shoot:
      "He can't be any more dead than he already is. Besides, Cortez and the rest of the gang would hear the shot and they'd be firing at you before you know it.";
  ],
has animate;

