      if (self.time_left < 3)
        print "the chatter of the bandits over ";
      "the crackling sound of the campfire.";
  ],
  daemon
  [;
    self.time_left++;
    switch (self.time_left)
    {
      1: "^The bandits haven't seen you yet.";
      2: "^Despite hearing someone approaching, the bandits keep drinking their coffee. They must think you're the bandit who went for water.";
      3: "^Cortez turns around and sees you. He quickly realises that you're not one of his men, so he draws his weapon. He's blazing fast!";
      4: deadflag = 1;
        "^Without a second thought, Cortez opens fire on you and is quickly followed by the other three members of his gang. You were so close to putting Cortez's career to an end. So close...";
    }
  ],
  time_left 0,
has light;

