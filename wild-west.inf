!========================================
! Room 20: Clearing
!========================================
Object room20 "Clearing"
with
  description "The clearing is crossed by paths that branch off in different directions. Possibly due to the proximity to the river, the ground is softer here so you can clearly make out horses' tracks heading north. You can go back to the river bank by going east.",
  n_to
  [;
    if (water has general && dead_outlaw in nothing)
      "Not yet. There's an outlaw approaching.";
    else
    return room21;
  ],
  e_to
  [;
    if (water has general && dead_outlaw in nothing)
      "Not now. You need to wait and see if the outlaws come for the poisoned water.";
    else
      return room19;
  ],
  before
  [;
    Hide:
      if (water has general)
        "You're already hiding.";
    Hint:
      if (room21 hasnt visited)
        "Follow the horses' tracks.";
      if (water hasnt general)
        "There's no point hanging around here. It's time to make use of the shaman's gift.";
      if (dead_outlaw in nothing)
        "Be patient. Wait for one of the outlaws to come for the poisoned water.";
      "It's safe to head back to the clearing now.";
  ],
has light;

!----------------------------------------
! Clearing (floating object)
!----------------------------------------
Object "clearing"
with
  name 'clearing' 'ground',
  description "It's an open space clear of trees. The ground is soft and covered with horses' tracks.",
  found_in room20 room21,
has scenery;

!========================================
! Room 21: Above Cortez's Hideout
!========================================
Object room21 "Above Cortez's Hideout"
with
  description "This flat clearing is on the top of a hill overlooking Cortez's hideout. The gang is camped a little further down the hill to the east and the clearing continues to the south. The gang's horses are tethered to some bushes and these bushes conceal you from the gang.",
  e_to room22,!Conditional & start daemon, see below
  s_to room20,
  d_to room22,!Conditional & start daemon, see below
  before
  [;
    Go:
      if (selected_direction == e_to or d_to)
      {
        if (water hasnt general && revolver notin player)
          print_ret (string)THAT_WOULD_BE_SUICIDE;
        if (water hasnt general)
          "As you start to make a move, you see that there are five bandits in the camp, but you only have ", bullets.number, " bullets in your revolver. You need to improve the odds.";
        if (dead_outlaw notin self)
          "Don't be so impatient. The bandits may soon come for some water.";
        if (revolver notin player && rifle notin player)
          print_ret (string)THAT_WOULD_BE_SUICIDE;
        room22.time_left = 0;
        StartDaemon(room22);
      }
    Hide:
      print "There's nowhere to hide here, so you head back to the clearing to the south.^^";
      PlayerTo(room20, 2);
      rtrue;
    Hint:
      if (water hasnt general)
        "Have you looked in the saddle bags? It's time to use the shaman's gift.";
      if (dead_outlaw notin self)
        "Make yourself scarce.";
      if (revolver notin player && rifle notin player)
        "Make sure you're armed.";
      print_ret (string)TIME_TO_DEAL_WITH_BANDITS;
    Listen:
      "You can hear the bandits' voices coming from the east.";
    Smell:
      if (noun == nothing)
        "The aroma of fresh coffee comes from the east.";
  ],
  daemon
  [;
    self.time_left++;
    if (self.time_left == 2)
    {
      print "^You're in luck. You don't have to wait long when you hear footsteps approaching";
      if (player notin self)
        " the clearing to the north.";
      print ", so you quickly vacate the area.^^";
      PlayerTo(room20, 2);
      rtrue;
    }
    if (self.time_left == 3)
    {
      move rifle to self;
      move dead_outlaw to self;
      move canteen to self;
      remove water;
      give canteen open;
      StopDaemon(self);
      "^You hear one of the outlaws approach the horses, so you watch him to see what he does. He takes the canteen and drinks from it. In a matter of seconds, the poison enters his system and he falls to the ground. It should now be safe to return to see if he's dead.";
    }
  ],
  time_left 0,
has light;

